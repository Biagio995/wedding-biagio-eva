APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Wedding event page (fill when you have final details)
WEDDING_EVENT_TITLE="Our wedding"
WEDDING_EVENT_DATE="2027-06-26 19:00"
WEDDING_EVENT_TIMEZONE=Europe/Athens
WEDDING_LOCATION_NAME="Venue TBD"
# WEDDING_LOCATION_ADDRESS="Street, City"
# WEDDING_MAPS_URL="https://www.google.com/maps/..."
WEDDING_DESCRIPTION="We would love to celebrate with you."
# WEDDING_ADDITIONAL_NOTES="Dress code: …\nParking: …"

# US-08: optional RSVP confirmation email (requires MAIL_* and guest email)
WEDDING_SEND_RSVP_CONFIRMATION_EMAIL=false
# US-24: optional email to you when a guest submits/updates RSVP (requires MAIL_*)
# WEDDING_ADMIN_RSVP_NOTIFY_EMAIL=you@example.com

# US-25: optional scheduled RSVP reminders for guests who have not responded (requires MAIL_* and guest email)
# WEDDING_RSVP_REMINDERS_ENABLED=false
# WEDDING_RSVP_REMINDER_COOLDOWN_DAYS=14

# US-16: admin (guest management). bcrypt hash of your password, e.g. tinker: Hash::make('secret')
WEDDING_ADMIN_PASSWORD_HASH=password
# US-18: optional limits for CSV guest import
# WEDDING_ADMIN_CSV_MAX_ROWS=500
# WEDDING_ADMIN_CSV_MAX_KB=1024

# Gallery (US-11 image compression)
GALLERY_IMAGE_COMPRESSION=true
# US-26: upload limits (validation uses file contents, not extension alone)
# GALLERY_UPLOAD_MAX_KB=10240
# GALLERY_UPLOAD_MAX_FILES=20
# US-27: POST /gallery submissions per IP per minute
# GALLERY_UPLOAD_RATE_PER_MINUTE=30
# GALLERY_MAX_DIMENSION=2048
# GALLERY_JPEG_QUALITY=85
# US-13: public album / infinite scroll
# GALLERY_PUBLIC_ONLY_APPROVED=false
# GALLERY_FEED_PER_PAGE=12
# US-30: HTTP cache hints (seconds; 0 disables Cache-Control for that response)
# GALLERY_FEED_HTTP_MAX_AGE=30
# GALLERY_DOWNLOAD_HTTP_MAX_AGE=86400
